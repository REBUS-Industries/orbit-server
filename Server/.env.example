# ORBIT Server — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# ── Server ────────────────────────────────────────────────────────────────────
# VM 211 (prod): SERVER_URL=https://orbit.rebus.industries
# VM 212 (dev):  SERVER_URL=https://orbit-dev.rebus.industries
SERVER_NAME=ORBIT
SERVER_URL=https://orbit.rebus.industries

# Random string, min 32 chars. Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=orbit
POSTGRES_USER=orbit
POSTGRES_PASSWORD=CHANGE_ME

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
MINIO_USER=orbitadmin
MINIO_PASSWORD=CHANGE_ME

# ── File size limits ──────────────────────────────────────────────────────────
FILE_SIZE_LIMIT_MB=1000

# ── Email (optional — leave blank to disable email notifications) ─────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=orbit@rebus.industries

# ── PRISM ─────────────────────────────────────────────────────────────────────
RHINOCOMPUTE_URL=http://compute.rebus.industries

# ── Docker image versions ─────────────────────────────────────────────────────
ORBIT_SERVER_VERSION=latest
ORBIT_FRONTEND_VERSION=v2.4.8
ORBIT_PREVIEW_VERSION=latest
ORBIT_PRISM_VERSION=latest
