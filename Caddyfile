# ORBIT Server internal Caddy
# Routes requests to the correct service within the Docker stack.
# Runs inside the Docker network - TLS termination at external HA proxy pair.

:80 {
    # GraphQL / API / Auth / Objects -> orbit-server
    @backend path /graphql /api/* /auth/* /objects/* /preview/* /blob/*
    reverse_proxy @backend orbit-server:3000

    # Public API documentation (markdown rendered by orbit-docs)
    @docs path /docs /docs/*
    reverse_proxy @docs orbit-docs:3080

    # Frontend - catch-all
    reverse_proxy orbit-frontend:8080
}
