<Project>
  <!--
    Local development override.
    Set OrbitSdkLocal=true so all projects in this solution reference the SDK
    by project reference rather than a NuGet package.
    OrbitSdkPath must point to the SDK src folder containing Orbit.Objects/ and Orbit.Sdk/.
  -->
  <PropertyGroup>
    <OrbitSdkLocal>true</OrbitSdkLocal>
    <OrbitSdkPath>D:\Documents\Claude\REBUS System\ORBIT\SDK\src</OrbitSdkPath>
  </PropertyGroup>
</Project>
