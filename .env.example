# ORBIT Server — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# ── Server ────────────────────────────────────────────────────────────────────
# VM 211 (prod): SERVER_URL=https://orbit.rebus.industries
# VM 212 (dev):  SERVER_URL=https://orbit-dev.rebus.industries
SERVER_NAME=ORBIT
SERVER_URL=https://orbit.rebus.industries

# Random string, min 32 chars. Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Must match SERVER_URL (the public URL of this server)
FRONTEND_ORIGIN=https://orbit.rebus.industries

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=orbit
POSTGRES_USER=orbit
POSTGRES_PASSWORD=CHANGE_ME

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
MINIO_USER=orbitadmin
MINIO_PASSWORD=CHANGE_ME

# ── File size limits ──────────────────────────────────────────────────────────
FILE_SIZE_LIMIT_MB=1000

# ── Email (optional — leave blank to disable email notifications) ─────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=orbit@rebus.industries

# Optional GHCR read token (PAT with read:packages) - required to pull private ghcr.io/rebus-orbit/* images
# GHCR_TOKEN=
# GHCR_USER=REBUS-ORBIT
ORBIT_SERVER_VERSION=latest
ORBIT_FRONTEND_VERSION=latest
# ORBIT-branded frontend source (CheekiSkrub/speckle-server-dev @ branch rebus-dev).
# Must be a rebus-dev commit / REBUS-v* tag ? NOT the fork's stock `main`.
ORBIT_FRONTEND_SOURCE_COMMIT=173d64210351c0b16a64437aaeb6e3dddf5eeada
