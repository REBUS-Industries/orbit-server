+  private getModelRootCollection(): TreeNode | null {
+    return this.subtree?.children?.[0] ?? null
+  }
+
+  private getInstanceDefinitionMemberApplicationIds(): Set<string> {
+    const memberIds = new Set<string>()
+    for (const k in this.instanceDefinitionLookupTable) {
+      const definition = this.instanceDefinitionLookupTable[k]
+      const objects = this.getInstanceProxyDefinitionObjects(definition.model.raw)
+      for (let i = 0; i < objects.length; i++) {
+        memberIds.add(objects[i].toString())
+      }
+    }
+    return memberIds
+  }
+
+  private storeInstancedDefinitionObject(
+    applicationId: string,
+    raw: SpeckleObject,
+    parentRaw?: SpeckleObject
+  ) {
+    if (this.instancedObjectsLookupTable[applicationId]) return
+
+    this.instancedObjectsLookupTable[applicationId] = raw
+    if (!this.instanceProxies[applicationId]) {
+      const parentApplicationId = parentRaw?.applicationId
+      if (parentApplicationId !== undefined) {
+        this.instancedObjectsLookupTable[applicationId].parentLayerApplicationId =
+          parentApplicationId.toString()
+      }
+    } else {
+      const definitionId = this.instanceProxies[applicationId].model.raw.definitionId
+      const proxies = Object.values(this.instanceProxies)
+      proxies.forEach((value: TreeNode) => {
+        if (value.model.raw.definitionId === definitionId) {
+          value.model.raw.parentLayerApplicationId =
+            value.parent.model.raw.applicationId
+        }
+      })
+    }
+  }
+
+  private async indexInstanceDefinitionGeometry(memberIds: Set<string>) {
+    const rootCollection = this.getModelRootCollection()
+    if (!rootCollection) return
+
+    const definitionGeometry =
+      rootCollection.model.raw['@instanceDefinitionGeometry'] ??
+      rootCollection.model.raw.instanceDefinitionGeometry
+    if (!Array.isArray(definitionGeometry)) return
+
+    for (const ref of definitionGeometry) {
+      if (typeof ref !== 'object' || ref === null) continue
+      const obj = await this.resolveReference(ref as SpeckleObject)
+      const applicationId = obj.applicationId?.toString()
+      if (!applicationId || !memberIds.has(applicationId)) continue
+      this.storeInstancedDefinitionObject(
+        applicationId,
+        obj,
+        rootCollection.model.raw
+      )
+    }
+  }
+
